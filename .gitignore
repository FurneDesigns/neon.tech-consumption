# ----------------------------------------------------------------------------
# Credentials and configuration (NEVER COMMIT)
# ----------------------------------------------------------------------------
.env
.env.*
!.env.example
.env.local
.env.neon
.envrc
config.json
config.*.json
*.pem
*.key
*.cert
*secret*
*credentials*

# ----------------------------------------------------------------------------
# Private user data (real consumption snapshots and invoice records)
# ----------------------------------------------------------------------------
data.json
data.*.json
history.json
invoices.json
snapshots/

# ----------------------------------------------------------------------------
# Node.js
# ----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.yarn/
.npm/
.pnp.*

# ----------------------------------------------------------------------------
# Build / coverage / test output
# ----------------------------------------------------------------------------
dist/
build/
out/
coverage/
*.tsbuildinfo
.cache/

# ----------------------------------------------------------------------------
# Editors and IDEs
# ----------------------------------------------------------------------------
.idea/
.vscode/
.cursor/
*.code-workspace
*.swp
*.swo
*.swn
*~

# ----------------------------------------------------------------------------
# OS-generated files
# ----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
# Windows alternate data streams created by WSL when copying from NTFS
*:Zone.Identifier

# ----------------------------------------------------------------------------
# Logs and runtime
# ----------------------------------------------------------------------------
*.log
*.pid
*.seed
*.pid.lock
logs/
