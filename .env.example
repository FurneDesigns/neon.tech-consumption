# Optional. The dashboard's Settings panel can store these in `config.json`
# (gitignored) instead. Use this file if you prefer environment variables,
# e.g. for CI or container deployments.

# Neon API key. Get one at:
#   console.neon.tech → avatar → Account settings → API keys (personal)
#   or org context → Settings → API keys (org-scoped, admin role required)
NEON_API_KEY=napi_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of organization IDs to track on first run.
# Format: org-xxxxxxxx-xxxxxxxx[,org-yyyyyyyy-yyyyyyyy]
# Get them with:
#   curl -H "Authorization: Bearer $NEON_API_KEY" https://console.neon.tech/api/v2/users/me/organizations
ORG_ID=org-xxxxxxx-xxxxxxxx

# Local server port (optional, default 3000)
# PORT=3000
